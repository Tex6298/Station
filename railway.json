{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "node scripts/railway-build.mjs",
    "watchPatterns": [
      "apps/api/**",
      "apps/web/**",
      "packages/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "scripts/railway-*.mjs",
      "tsconfig.base.json",
      "turbo.json",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "node scripts/railway-start.mjs",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
