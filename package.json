{
  "name": "station",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:auth": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth build && tsx --test apps/api/src/routes/auth.test.ts apps/web/lib/auth-routes.test.ts apps/web/lib/auth-session.test.ts apps/web/lib/password-reset.test.ts",
    "test:developer-spaces": "tsx --test apps/api/src/routes/developer-spaces.test.ts apps/web/lib/developer-space-observatory.test.ts",
    "test:spaces": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth build && tsx --test apps/api/src/routes/spaces.test.ts",
    "test:billing": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth build && tsx --test apps/api/src/routes/billing.test.ts apps/web/lib/billing-plan-actions.test.ts",
    "test:storage": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth --filter @station/ai build && tsx --test apps/api/src/routes/storage.test.ts",
    "test:integrity": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth --filter @station/ai build && tsx --test apps/api/src/routes/integrity.test.ts",
    "test:token-credits": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth build && tsx --test apps/api/src/routes/token-credits.test.ts",
    "test:health": "tsx --test apps/api/src/routes/health.test.ts apps/web/lib/deployment-identity.test.ts",
    "test:projects": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth build && tsx --test apps/api/src/routes/projects.test.ts",
    "test:replay-readiness": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth build && tsx --test apps/api/src/routes/replay-readiness.test.ts",
    "test:studio-ui": "tsx --test apps/web/lib/studio-navigation.test.ts apps/web/lib/onboarding-paths.test.ts apps/web/lib/archive-trust.test.ts apps/web/lib/export-trust.test.ts apps/web/lib/publishing-ui.test.ts apps/web/lib/import-review.test.ts apps/web/lib/station-assistant-ui.test.ts apps/web/lib/chat-stream.test.ts apps/web/lib/memory-lifecycle-ui.test.ts apps/web/lib/ai-observability-ui.test.ts apps/web/lib/persona-lifecycle-ui.test.ts apps/web/lib/integrity-ui.test.ts apps/web/lib/moderation-console.test.ts apps/web/lib/report-resolution.test.ts apps/web/lib/community-notifications.test.ts apps/web/lib/community-subcommunities.test.ts apps/web/lib/community-forum-create.test.ts apps/web/lib/community-witness.test.ts apps/web/lib/community-moderation.test.ts apps/web/lib/delegated-moderation-queue.test.ts",
    "test:publishing-approvals": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth build && tsx --test apps/api/src/routes/publishing-approvals.test.ts apps/web/lib/publishing-ui.test.ts",
    "test:writing": "tsx --test apps/web/lib/writing-feed.test.ts apps/web/lib/public-story-polish.test.ts",
    "test:reports": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth build && tsx --test apps/api/src/routes/reports.test.ts",
    "test:community": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth build && tsx --test apps/api/src/routes/community.test.ts",
    "test:continuity": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth --filter @station/ai build && tsx --test apps/api/src/routes/continuity.test.ts apps/api/src/routes/continuity-records.test.ts apps/web/lib/continuity-ui.test.ts",
    "test:persona-context": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth --filter @station/ai build && tsx --test apps/api/src/routes/persona-context.test.ts apps/api/src/services/conversation-history.service.test.ts",
    "test:conversation-archive": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth --filter @station/ai build && tsx --test apps/api/src/routes/conversation-archive.test.ts apps/api/src/routes/archive-retrieval.test.ts apps/api/src/services/conversation-history.service.test.ts apps/api/src/services/imports/parsers/import-parsers.test.ts",
    "test:continuity-publication": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth --filter @station/ai build && tsx --test apps/api/src/routes/continuity-publication.test.ts",
    "test:document-discussions": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth --filter @station/ai build && tsx --test apps/api/src/routes/document-discussions.test.ts",
    "test:exports": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth --filter @station/ai build && tsx --test apps/api/src/routes/exports.test.ts",
    "test:developer-space-client": "pnpm --filter @station/developer-space-client test",
    "replay:seed:staging": "node scripts/staging-replay-seed.mjs",
    "replay:seed:validate": "node scripts/staging-replay-seed.mjs --validate-corpus docs/ops/STAGING_REPLAY_CORPUS.example.json",
    "triad:watch:mimir": "node scripts/triad-watch.mjs A1 --watch",
    "triad:watch:daedalus": "node scripts/triad-watch.mjs A2 --watch",
    "triad:watch:argus": "node scripts/triad-watch.mjs A3 --watch",
    "triad:watch:ariadne": "node scripts/triad-watch.mjs A4 --watch",
    "triad:status": "node scripts/triad-status.mjs",
    "test:assistant": "pnpm --filter @station/types --filter @station/config --filter @station/db --filter @station/auth --filter @station/ai build && tsx --test apps/api/src/services/station-assistant.service.test.ts apps/api/src/services/conversation-history.service.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.4"
  }
}
