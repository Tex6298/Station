NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# API runtime
PORT=4000
JWT_SECRET=

# Supabase API auth/database (server-side)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
SUPABASE_POOLER_URL=
SUPABASE_ACCESS_TOKEN=

# Supabase browser auth client (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI - NVIDIA AI integration (platform chat, OpenAI-compatible)
NVIDIA_AI_API_KEY=
NVIDIA_MODEL_BASE_URL=https://integrate.api.nvidia.com
NVIDIA_MODEL=openai/gpt-oss-120b

# AI - Platform chat (DeepSeek, Mode B)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# AI - Embeddings
# Use an embedding profile as the product/runtime contract. The current free-tier
# product-testing profile is backed by Gemini, but routes/workspaces should bind
# to profile codes rather than hardcoding provider names.
OPENAI_API_KEY=
EMBEDDING_PROFILE_CODE=station_free_1536
EMBEDDING_MODEL=
EMBEDDING_DIM=1536
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Staging replay seed helper (local/operator-only; never commit credentials or
# the local corpus file)
STATION_REPLAY_OWNER_EMAIL=
STATION_REPLAY_OWNER_PASSWORD=
STATION_REPLAY_OWNER_USERNAME=station-replay-owner
STATION_REPLAY_CORPUS_PATH=docs/ops/staging-replay-corpus.local.json

# AI - Cloudflare retrieval adapter (optional/deferred; disabled by default)
CLOUDFLARE_RETRIEVAL_ENABLED=false
CLOUDFLARE_RETRIEVAL_WORKER_URL=
CLOUDFLARE_RETRIEVAL_API_TOKEN=
CLOUDFLARE_VECTORIZE_INDEX=

# Stripe - Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe - Price IDs (create products in dashboard, paste IDs here)
# Basic - GBP 10/month
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=

# Creator - GBP 100/month or GBP 1000/year
STRIPE_PRICE_CREATOR_MONTHLY=
STRIPE_PRICE_CREATOR_YEARLY=

# Canon - GBP 250/month
STRIPE_PRICE_CANON_MONTHLY=
STRIPE_PRICE_CANON_YEARLY=

# Social publishing - OAuth app credentials
# Tumblr:   https://www.tumblr.com/oauth/apps
# LinkedIn: https://www.linkedin.com/developers/apps
# Reddit:   https://www.reddit.com/prefs/apps (choose "web app", redirect URI = API_URL/social/callback/reddit)
TUMBLR_CLIENT_ID=
TUMBLR_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Email
RESEND_API_KEY=

# Observability
POSTHOG_KEY=
POSTHOG_HOST=
SENTRY_DSN=

# Developer Spaces SSE tuning (optional)
DEVELOPER_SPACE_SSE_POLL_MS=5000

# Upstash database (optional, for caching or other use cases)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional OpenAI-native/rollback profile values. Leave EMBEDDING_MODEL blank
# unless deliberately overriding with a model that matches the selected profile.
# EMBEDDING_PROFILE_CODE=openai_1536
# EMBEDDING_MODEL=text-embedding-3-small
