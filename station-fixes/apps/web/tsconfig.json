{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/components/*": [
        "./components/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@station/ai": [
        "../../packages/ai/src/index.ts"
      ],
      "@station/ai/*": [
        "../../packages/ai/src/*"
      ],
      "@station/auth": [
        "../../packages/auth/src/index.ts"
      ],
      "@station/auth/*": [
        "../../packages/auth/src/*"
      ],
      "@station/config": [
        "../../packages/config/src/index.ts"
      ],
      "@station/config/*": [
        "../../packages/config/src/*"
      ],
      "@station/db": [
        "../../packages/db/src/index.ts"
      ],
      "@station/db/*": [
        "../../packages/db/src/*"
      ],
      "@station/types": [
        "../../packages/types/src/index.ts"
      ],
      "@station/types/*": [
        "../../packages/types/src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "incremental": true,
    "isolatedModules": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
